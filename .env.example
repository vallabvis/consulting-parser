# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # NEVER expose to browser

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
# Used by Tier 1 scraper (claude-haiku-4-5-20251001) and the /api/extract endpoint
ANTHROPIC_API_KEY=sk-ant-...

# ─── Resend (email reminders) ────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_stub_replace_in_production

# ─── Cron security ───────────────────────────────────────────────────────────
# Protects /api/cron/tier1-scraper, /api/cron/tier2-ats, /api/ingest/greenhouse, /api/reminders
# Generate: openssl rand -base64 32
# Set the same value in Vercel → Settings → Environment Variables
# Vercel cron passes it automatically as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace_with_a_long_random_string

# ─── Admin notifications (optional) ─────────────────────────────────────────
# Slack incoming webhook URL to ping when a member submits an opportunity
# Leave unset to disable notifications
ADMIN_NOTIFY_WEBHOOK=https://hooks.slack.com/services/...

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
